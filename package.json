{
  "name": "@frourio/next",
  "version": "0.0.0",
  "description": "Next.js Route Handlers helper with runtime validation and type-safe clients",
  "author": "Solufa",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "frourio-next": "bin/index.js",
    "frourio-next-msw": "bin/msw.js",
    "frourio-next-openapi": "bin/openapi.js"
  },
  "scripts": {
    "dev": "npm run build && npm run generate",
    "generate": "node projects/dev.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "homepage": "https://github.com/frouriojs/frourio-next#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/frourios/frourio-next"
  },
  "files": [
    "dist",
    "llms-full.txt"
  ],
  "keywords": [
    "typescript",
    "nextjs",
    "frourio"
  ],
  "dependencies": {
    "chokidar": "^4.0.3",
    "minimist": "^1.2.8",
    "openapi-types": "^12.1.3",
    "typescript-json-schema": "^0.65.1"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@frourio/next": "file:dist",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/minimist": "^1.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ai": "^6.0.116",
    "cookie": "^1.1.1",
    "happy-dom": "^20.8.4",
    "msw": "^2.12.13",
    "next": "^15.5.12",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "swr": "^2.4.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
