{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "sortPackageJson": false,
  "sortImports": {
    "newlinesBetween": false
  },
  "ignorePatterns": [
    "dist",
    "projects/**/frourio.client.ts",
    "projects/**/frourio.server.ts",
    "projects/**/frourio.middleware.ts",
    "projects/**/setupMswHandlers.ts",
    "*.json",
    "$*.ts"
  ]
}
